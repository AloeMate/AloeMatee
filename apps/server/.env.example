# Application Configuration
APP_NAME=AloeVeraMate API
APP_VERSION=1.0.0
DEBUG=True

# Server Configuration
HOST=0.0.0.0
PORT=8000

# CORS Configuration
# For Expo development, use "*" to allow all origins
# In production, specify exact origins: ["http://your-app.com", "https://your-app.com"]
# Expo dev clients work with "*" or specific exp:// schemes
ALLOWED_ORIGINS=["*"]

# File Upload Settings
MAX_UPLOAD_SIZE=10485760  # 10MB in bytes
ALLOWED_EXTENSIONS=["jpg", "jpeg", "png"]

# ML Model Configuration (currently using deterministic hash model)
MODEL_PATH=
CONFIDENCE_THRESHOLD=0.3

# MongoDB Configuration (for IoT Component)
# Get connection string from MongoDB Atlas or your local MongoDB instance
MONGODB_URI=mongodb://localhost:27017
# Example Atlas URI format:
# MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/

# RAG — Treatment Guidance System (Gemini + ChromaDB)
RAG_ENABLED=True
# Get your API key from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-1.5-flash
GEMINI_EMBED_MODEL=models/text-embedding-004
RAG_CHROMA_PATH=data/chroma_db
RAG_COLLECTION=aloe_treatment_knowledge
RAG_TOP_K=4
